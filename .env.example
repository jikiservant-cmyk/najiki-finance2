# Database
# Supabase PostgreSQL connection strings (from Supabase Dashboard > Project Settings > Database > Connection String > Pooler)
# DATABASE_URL: Used by Prisma at runtime (through PgBouncer, port 6543, Transaction mode)
# DIRECT_URL: Used by Prisma for migrations only (direct connection, port 5432, bypasses pooler)
# Replace [YOUR-PASSWORD] with your actual Supabase database password!
DATABASE_URL="postgresql://postgres.vzvtirgkjvhnnqwmpsbj:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.vzvtirgkjvhnnqwmpsbj:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# LivePay Configuration
LIVEPAY_API_KEY="your-livepay-api-key"
LIVEPAY_ACCOUNT_NO="your-livepay-account-number"
LIVEPAY_WEBHOOK_SECRET="your-livepay-webhook-secret"
LIVEPAY_BASE_URL="https://livepay.me"

# Africa's Talking Configuration
AFRICASTALKING_API_KEY="your-africastalking-api-key"
AFRICASTALKING_USERNAME="your-africastalking-username"

# App URL (for webhook verification)
NEXTAUTH_URL="http://localhost:3000"
